generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "mysql"
}

// --- NextAuth adapter models ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Core models ---

model Network {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  units     Unit[]
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Unit {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  networkId String
  erpId     Int?       @unique  // ERP: unidades.id
  cidade    String?
  estado    String?
  telefone  String?
  email     String?
  network   Network    @relation(fields: [networkId], references: [id], onDelete: Cascade)
  users     UserUnit[]

  churnPredictions ChurnPrediction[]
  churnAcoes       ChurnAcao[]
  churnLogs        ChurnLog[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([networkId])
}

model User {
  id           String                 @id @default(cuid())
  email        String                 @unique
  name         String
  passwordHash String?
  image        String?
  role         Role                   @default(COLABORADOR)
  networkId    String?
  network      Network?               @relation(fields: [networkId], references: [id])
  units        UserUnit[]
  permissions  UserModulePermission[]
  accounts     Account[]
  sessions     Session[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([networkId])
}

model UserUnit {
  userId String
  unitId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit   Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@id([userId, unitId])
  @@index([unitId])
}

enum Role {
  SUPER_ADMIN
  FRANQUEADOR
  MULTIFRANQUEADO
  GERENTE
  COLABORADOR
}

enum ChurnStatus {
  ativo
  em_risco
  em_risco_alto
  perdido
}

enum ChurnAcaoType {
  email
  sms
  whatsapp
  desconto
  alerta
}

enum ChurnAcaoStatus {
  pendente
  enviado
  falhou
  ignorado
  respondeu
}

enum ChurnProcessamentoType {
  diario
  manual
  agendado
}

enum ChurnLogStatus {
  success
  error
}

model UserModulePermission {
  id     String  @id @default(cuid())
  userId String
  unitId String?
  module Module
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, unitId, module])
  @@index([userId])
}

enum Module {
  BARBERSHOP
  LINKFOOD
  WAHASEND
  VIPCAM
  VIP_DATA
  TOTALIA
  INSTAGRAM
}

// ============================================================
// TOTALIA MODULE TABLES
// ============================================================

model TotaliaColaborador {
  id             String    @id @default(cuid())
  unitId         String
  userId         String?
  nome           String
  email          String?
  telefone       String?
  cargo          String?
  area           String?
  areaAtuacao    String?
  ativo          Boolean   @default(true)
  grupoId        String?
  tipoUsuario    String    @default("colaborador") // admin|gestor|colaborador
  conviteEnviado Boolean   @default(false)
  conviteAceito  Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tasks          TotaliaTask[]
  @@index([unitId])
}

model TotaliaCargo {
  id                String   @id @default(cuid())
  unitId            String
  nome              String
  descricao         String?  @db.Text
  area              String?
  nivel             String?
  ativo             Boolean  @default(true)
  salarioMin        Float?
  salarioMax        Float?
  requisitos        Json     @default("[]")
  responsabilidades Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([unitId])
}

model TotaliaTask {
  id                     String    @id @default(cuid())
  unitId                 String
  titulo                 String
  descricao              String?   @db.Text
  area                   String?
  prioridade             String?
  status                 String    @default("A Fazer")
  dueDate                DateTime?
  estimativaHoras        Float?
  processoRelacionado    String?
  responsavelId          String?
  responsavel            TotaliaColaborador? @relation(fields: [responsavelId], references: [id])
  participantes          Json      @default("[]")
  dependsOn              Json      @default("[]")
  checklist              Json      @default("[]")
  criteriosAceite        Json      @default("[]")
  evidenciasRequeridas   Json      @default("[]")
  relacaoObjetivos       Json      @default("[]")
  valoresAderentes       Json      @default("[]")
  riscosMitigados        Json      @default("[]")
  notasExecucao          String?   @db.Text
  plano                  Json?
  recorrencia            String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([unitId])
  @@index([responsavelId])
}

model TotaliaProcess {
  id                  String   @id @default(cuid())
  unitId              String
  name                String
  type                String   @default("principal") // principal|apoio
  description         String?  @db.Text
  detailedDescription String?  @db.Text
  status              String   @default("ativo")
  activities          Json     @default("[]")
  area                String?
  objective           String?  @db.Text
  kpis                Json?
  checklists          Json?
  implementationSteps Json     @default("[]")
  requiredResources   Json     @default("[]")
  successMetrics      Json     @default("[]")
  risks               Json     @default("[]")
  estimatedDuration   String?
  responsibleRoles    Json     @default("[]")
  hasDetailedInfo     Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([unitId])
}

model TotaliaStrategicPlanning {
  id               String   @id @default(cuid())
  unitId           String   @unique
  mission          String?  @db.Text
  vision           String?  @db.Text
  values           String?  @db.Text
  swotStrengths    Json     @default("[]")
  swotWeaknesses   Json     @default("[]")
  swotOpportunities Json    @default("[]")
  swotThreats      Json     @default("[]")
  objectives       Json     @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TotaliaFinancialCategory {
  id        String   @id @default(cuid())
  unitId    String
  name      String
  type      String   // receita|despesa
  parentId  String?
  parent    TotaliaFinancialCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  TotaliaFinancialCategory[] @relation("CategoryHierarchy")
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       TotaliaFinancialAccount[]
  budgetItems    TotaliaBudgetPlanning[]
  @@index([unitId])
  @@index([parentId])
}

model TotaliaFinancialAccount {
  id            String    @id @default(cuid())
  unitId        String
  type          String    // receivable|payable
  amount        Float
  description   String
  categoryId    String?
  category      TotaliaFinancialCategory? @relation(fields: [categoryId], references: [id])
  dueDate       DateTime?
  status        String    @default("pendente") // pendente|pago|cancelado
  paymentDate   DateTime?
  recurringRule Json?
  tags          Json      @default("[]")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([unitId])
  @@index([categoryId])
}

model TotaliaBudgetPlanning {
  id             String   @id @default(cuid())
  unitId         String
  year           Int
  month          Int
  categoryId     String
  category       TotaliaFinancialCategory @relation(fields: [categoryId], references: [id])
  plannedAmount  Float    @default(0)
  actualAmount   Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([unitId, year, month, categoryId])
  @@index([unitId])
}

model TotaliaPaymentMethod {
  id                 String   @id @default(cuid())
  unitId             String
  name               String
  description        String?
  isActive           Boolean  @default(true)
  discountPercentage Float    @default(0)
  paymentDays        Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([unitId])
}

model TotaliaRisk {
  id               String    @id @default(cuid())
  unitId           String
  title            String
  description      String?   @db.Text
  origin           String?
  probability      String?
  impact           String?
  detectionDate    DateTime?
  reviewDate       DateTime?
  status           String    @default("identificado")
  assignedTo       String?
  assignedAt       DateTime?
  resolvedAt       DateTime?
  resolutionNotes  String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([unitId])
}

model TotaliaOpportunity {
  id               String    @id @default(cuid())
  unitId           String
  title            String
  description      String?   @db.Text
  origin           String?
  probability      String?
  impact           String?
  detectionDate    DateTime?
  reviewDate       DateTime?
  status           String    @default("identificada")
  assignedTo       String?
  assignedAt       DateTime?
  resolvedAt       DateTime?
  resolutionNotes  String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([unitId])
}

model TotaliaProblem {
  id               String    @id @default(cuid())
  unitId           String
  title            String
  description      String?   @db.Text
  origin           String?
  probability      String?
  impact           String?
  detectionDate    DateTime?
  reviewDate       DateTime?
  status           String    @default("identificado")
  assignedTo       String?
  assignedAt       DateTime?
  resolvedAt       DateTime?
  resolutionNotes  String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([unitId])
}

model TotaliaMarketingCampaign {
  id               String   @id @default(cuid())
  unitId           String
  campaignName     String
  version          Int      @default(1)
  status           String   @default("rascunho")
  inputs           Json?
  outputs          Json?
  wizardResponses  Json?
  budgetSplit      Json?
  channelMix       Json?
  personas         Json?
  adsKits          Json?
  landingCopy      Json?
  assumptions      Json?
  kpisTargets      Json?
  calendar90d      Json?
  crmFlows         Json?
  executiveSummary String?  @db.Text
  messages         Json?
  pdfUrl           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([unitId])
}

model TotaliaMeeting {
  id              String   @id @default(cuid())
  unitId          String
  title           String
  description     String?  @db.Text
  meetingDate     DateTime
  meetingTime     String?
  durationMinutes Int?
  location        String?
  meetingType     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([unitId])
}

model TotaliaSupplier {
  id             String   @id @default(cuid())
  unitId         String
  name           String
  cnpjCpf        String?
  contactPerson  String?
  email          String?
  phone          String?
  address        String?  @db.Text
  status         String   @default("ativo")
  paymentTerms   String?
  creditLimit    Float?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products       TotaliaProduct[]
  purchaseOrders TotaliaPurchaseOrder[]
  @@index([unitId])
}

model TotaliaProduct {
  id             String   @id @default(cuid())
  unitId         String
  name           String
  sku            String?
  description    String?  @db.Text
  category       String?
  unitOfMeasure  String?
  unitPrice      Float    @default(0)
  currentStock   Float    @default(0)
  minStock       Float    @default(0)
  status         String   @default("ativo")
  supplierId     String?
  supplier       TotaliaSupplier? @relation(fields: [supplierId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orderItems     TotaliaPurchaseOrderItem[]
  @@index([unitId])
  @@index([supplierId])
}

model TotaliaPurchaseOrder {
  id                   String    @id @default(cuid())
  unitId               String
  orderNumber          String
  supplierId           String?
  supplier             TotaliaSupplier? @relation(fields: [supplierId], references: [id])
  requestedBy          String?
  assignedTo           String?
  requestDate          DateTime?
  expectedDeliveryDate DateTime?
  deliveryDate         DateTime?
  status               String    @default("rascunho")
  priority             String?
  notes                String?   @db.Text
  totalAmount          Float     @default(0)
  discountAmount       Float     @default(0)
  taxAmount            Float     @default(0)
  finalAmount          Float     @default(0)
  approvalNotes        String?   @db.Text
  paymentMethodId      String?
  cancellationReason   String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  items                TotaliaPurchaseOrderItem[]
  @@index([unitId])
  @@index([supplierId])
}

model TotaliaPurchaseOrderItem {
  id               String   @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    TotaliaPurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId        String?
  product          TotaliaProduct? @relation(fields: [productId], references: [id])
  quantity         Float    @default(1)
  receivedQuantity Float    @default(0)
  unitPrice        Float    @default(0)
  totalPrice       Float    @default(0)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([purchaseOrderId])
  @@index([productId])
}

model TotaliaUserGroup {
  id          String   @id @default(cuid())
  unitId      String
  name        String
  description String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions TotaliaGroupPermission[]
  @@index([unitId])
}

model TotaliaGroupPermission {
  id             String           @id @default(cuid())
  groupId        String
  group          TotaliaUserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  module         String
  permissionType String
  enabled        Boolean          @default(false)
  createdAt      DateTime         @default(now())

  @@unique([groupId, module, permissionType])
  @@index([groupId])
}

model TotaliaAdvisorProfile {
  id          String   @id @default(cuid())
  unitId      String   @unique
  name        String?
  profileData Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TotaliaAdvisorKnowledge {
  id             String   @id @default(cuid())
  unitId         String   @unique
  knowledgeData  Json?
  isConfigured   Boolean  @default(false)
  referenceNames Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TotaliaAdvisorConversation {
  id        String   @id @default(cuid())
  unitId    String
  title     String?
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([unitId])
}

model TotaliaAuditLog {
  id             String   @id @default(cuid())
  userId         String?
  unitId         String
  tableName      String?
  action         String
  details        Json?
  ipAddress      String?
  userAgent      String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([unitId])
  @@index([userId])
}

// ─── Barbearia VIP ───────────────────────────────────────────────────────────

model BarbershopColaborador {
  id               String   @id @default(cuid())
  unitId           String
  erpId            Int?     // ERP: usuarios.id
  nome             String
  tipo             String?
  telefone         String?
  email            String?
  cor              String?  // cor no calendário (ERP: cor)
  comissaoServico  Float?   // ERP: comissao_servico
  comissaoProduto  Float?   // ERP: comissao_produto
  dataContratacao  DateTime? // ERP: data_contratacao
  ativo            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  vendas        BarbershopVenda[]
  regraComissao BarbershopRegraComissao[]
  metas         BarbershopMeta[]

  @@unique([unitId, erpId])
  @@index([unitId])
  @@index([erpId])
}

model BarbershopCliente {
  id                     String    @id @default(cuid())
  unitId                 String
  erpId                  Int?      // ERP: clientes.id
  nome                   String
  telefone               String?
  email                  String?
  cpf                    String?
  bairro                 String?
  cidade                 String?
  estado                 String?
  cep                    String?
  nascimento             DateTime?
  ativo                  Boolean   @default(true)
  pontuacao              Int?
  consumoTotal           Float?
  ultimaVisita           DateTime?
  ultimaVisitaUnidadeErp Int?      // ERP: ultima_visita_unidade
  tags                   String?   // ERP: tags (JSON string)
  origem                 String?   // ERP: origem (app, balcao, etc)
  statusCliente          String?   // ativo, em_risco, perdido, novo
  cadenciaDias           Int?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  vendas        BarbershopVenda[]
  churnPredictions ChurnPrediction[]
  churnAcoes    ChurnAcao[]
  churnLogs     ChurnLog[]

  @@unique([unitId, erpId])
  @@index([unitId])
  @@index([erpId])
}

model BarbershopVenda {
  id               String    @id @default(cuid())
  unitId           String
  vendaId          String    // external ID (deduplication)
  colaboradorId    String?
  colaboradorNome  String?
  clienteId        String?
  clienteNome      String?
  produto          String?
  categoria        String?   // servico | produto
  valorBruto       Float?
  valorLiquido     Float?
  formaPagamento   String?
  vendaData        DateTime?
  source           String?
  createdAt        DateTime  @default(now())

  colaborador      BarbershopColaborador? @relation(fields: [colaboradorId], references: [id])
  cliente          BarbershopCliente?     @relation(fields: [clienteId], references: [id])

  @@unique([unitId, vendaId])
  @@index([unitId])
  @@index([colaboradorId])
  @@index([clienteId])
  @@index([vendaData])
}

model BarbershopConfig {
  id        String   @id @default(cuid())
  unitId    String
  chave     String
  valor     Json

  @@unique([unitId, chave])
  @@index([unitId])
}

model BarbershopRegraComissao {
  id               String   @id @default(cuid())
  unitId           String
  colaboradorId    String?
  tipo             String   @default("geral") // geral | individual
  percentualFixo   Float?
  usaEscalonamento Boolean  @default(false)
  mes              Int
  ano              Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  colaborador      BarbershopColaborador? @relation(fields: [colaboradorId], references: [id])
  faixas           BarbershopFaixaComissao[]

  @@index([unitId])
  @@index([colaboradorId])
}

model BarbershopFaixaComissao {
  id          String   @id @default(cuid())
  regraId     String
  nome        String
  percentual  Float
  cor         String?
  faixaOrdem  Int

  regra       BarbershopRegraComissao @relation(fields: [regraId], references: [id], onDelete: Cascade)

  @@index([regraId])
}

model BarbershopMeta {
  id            String   @id @default(cuid())
  unitId        String
  colaboradorId String?
  tipo          String   // faturamento | atendimentos | ticket_medio | novos_clientes
  valor         Float
  mes           Int
  ano           Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  colaborador   BarbershopColaborador? @relation(fields: [colaboradorId], references: [id])

  @@index([unitId])
  @@index([colaboradorId])
}

// ─── LinkFood ─────────────────────────────────────────────────────────────────

model LinkfoodBusiness {
  id            String   @id @default(cuid())
  unitId        String
  name          String
  description   String?  @db.Text
  address       String?
  phone         String?
  website       String?
  image         String?  @db.Text
  category      String?
  googlePlaceId String?
  isHeadquarters Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  connections   LinkfoodPlatformConnection[]
  reviewSummary LinkfoodReviewSummary?

  @@index([unitId])
}

model LinkfoodPlatformConnection {
  id           String    @id @default(cuid())
  unitId       String
  businessId   String
  platform     String    // GOOGLE | TRIPADVISOR | FACEBOOK | YELP | MANUAL | etc.
  externalId   String?
  url          String?
  credentials  Json?
  isActive     Boolean   @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business     LinkfoodBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)
  reviews      LinkfoodReview[]

  @@unique([businessId, platform])
  @@index([unitId])
  @@index([businessId])
}

model LinkfoodReview {
  id                   String    @id @default(cuid())
  unitId               String
  businessId           String
  platformConnectionId String?
  externalId           String?
  platform             String
  rating               Float
  title                String?
  content              String?   @db.Text
  authorName           String?
  authorImage          String?
  reviewDate           DateTime?
  responseText         String?   @db.Text
  responseDate         DateTime?
  language             String?
  sentiment            String?   // POSITIVE | NEUTRAL | NEGATIVE
  isVerified           Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  connection           LinkfoodPlatformConnection? @relation(fields: [platformConnectionId], references: [id])

  @@unique([unitId, externalId, platform])
  @@index([unitId])
  @@index([businessId])
  @@index([platformConnectionId])
  @@index([reviewDate])
}

model LinkfoodReviewSummary {
  id                  String   @id @default(cuid())
  businessId          String   @unique
  averageRating       Float    @default(0)
  totalReviews        Int      @default(0)
  ratingsByPlatform   Json?
  ratingDistribution  Json?
  sentimentSummary    Json?
  updatedAt           DateTime @updatedAt

  business            LinkfoodBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model LinkfoodIntegrationConfig {
  id           String   @id @default(cuid())
  unitId       String
  platform     String
  configType   String   @default("API_KEY") // OAUTH | API_KEY | HYBRID
  clientId     String?
  clientSecret String?
  redirectUri  String?
  apiKey       String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([unitId, platform])
  @@index([unitId])
}

model LinkfoodChecklist {
  id          String   @id @default(cuid())
  unitId      String
  title       String
  description String?
  frequency   String   @default("DAILY") // DAILY | WEEKLY | MONTHLY
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       LinkfoodChecklistItem[]
  completions LinkfoodChecklistCompletion[]

  @@index([unitId])
}

model LinkfoodChecklistItem {
  id          String   @id @default(cuid())
  checklistId String
  title       String
  order       Int      @default(0)

  checklist   LinkfoodChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  completions LinkfoodChecklistCompletion[]

  @@index([checklistId])
}

model LinkfoodChecklistCompletion {
  id              String    @id @default(cuid())
  unitId          String
  checklistId     String
  checklistItemId String
  completedAt     DateTime  @default(now())
  completedBy     String?
  periodDate      DateTime?

  checklist       LinkfoodChecklist     @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  item            LinkfoodChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([checklistId])
  @@index([checklistItemId])
}

// ─── Instagram Automation ─────────────────────────────────────────────────────

model InstagramAccount {
  id        String   @id @default(cuid())
  unitId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  config       InstagramConfig?
  welcomeConfig InstagramWelcomeConfig?
  storyConfig  InstagramStoryReplyConfig?
  logs         InstagramActivityLog[]
  stats        InstagramBotStats[]
  approvals    InstagramApprovalQueue[]
  welcomeMsgs  InstagramWelcomeMessage[]
  watchAccounts InstagramWatchAccount[]

  @@index([unitId])
}

model InstagramConfig {
  id                    String    @id @default(cuid())
  unitId                String
  accountId             String    @unique
  accessToken           String?   @db.Text
  instagramUserId       String?
  igBusinessId          String?
  checkIntervalMinutes  Int       @default(5)
  dryRun                Boolean   @default(false)
  postsToMonitor        Int       @default(5)
  personalityPrompt     String?   @db.Text
  isActive              Boolean   @default(false)
  onlyNewComments       Boolean   @default(true)
  tokenExpiresAt        DateTime?
  maxRepliesPerCycle    Int       @default(10)
  appId                 String?
  appSecret             String?   @db.Text
  onboardingCompleted   Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  account   InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([unitId])
}

model InstagramActivityLog {
  id                 String   @id @default(cuid())
  unitId             String
  accountId          String
  type               String   // reply_posted | reply_simulated | spam_detected | error | bot_started | bot_stopped | check_run | welcome_sent
  postId             String?
  commentId          String?
  commenterUsername  String?
  commentText        String?  @db.Text
  replyText          String?  @db.Text
  meta               Json?
  createdAt          DateTime @default(now())

  account   InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([accountId])
  @@index([createdAt])
}

model InstagramBotStats {
  id               String   @id @default(cuid())
  unitId           String
  accountId        String
  date             String   // YYYY-MM-DD
  repliesPosted    Int      @default(0)
  repliesSimulated Int      @default(0)
  spamDetected     Int      @default(0)
  errorsCount      Int      @default(0)
  checksRun        Int      @default(0)

  account   InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])
  @@index([unitId])
  @@index([accountId])
}

model InstagramApprovalQueue {
  id                String    @id @default(cuid())
  unitId            String
  accountId         String
  postId            String?
  commentId         String?
  commenterUsername String?
  commentText       String?   @db.Text
  suggestedReply    String?   @db.Text
  status            String    @default("pending") // pending | approved | rejected | auto_approved | posted | failed
  sentiment         String?   // positive | neutral | negative | question | spam
  expiresAt         DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  postedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  account   InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([accountId])
  @@index([status])
}

model InstagramApprovalConfig {
  id                  String   @id @default(cuid())
  unitId              String
  accountId           String   @unique
  isActive            Boolean  @default(false)
  autoApproveMinutes  Int      @default(30)
  notifyByEmail       Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([unitId])
}

model InstagramWelcomeConfig {
  id                  String    @id @default(cuid())
  unitId              String
  accountId           String    @unique
  isActive            Boolean   @default(false)
  welcomePrompt       String?   @db.Text
  lastFollowersCount  Int?
  lastCheckedAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  account   InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([unitId])
}

model InstagramWelcomeMessage {
  id                    String   @id @default(cuid())
  unitId                String
  accountId             String
  followerUsername      String
  followerBio           String?  @db.Text
  followerFollowersCount Int?
  followerPostsCount    Int?
  generatedMessage      String?  @db.Text
  status                String   @default("pending") // pending | sent | dismissed
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  account   InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([accountId])
  @@index([status])
}

model InstagramWatchAccount {
  id                  String    @id @default(cuid())
  unitId              String
  accountId           String
  igUsername          String
  igUserId            String?
  customPrompt        String?   @db.Text
  isActive            Boolean   @default(true)
  onlyNewPosts        Boolean   @default(true)
  lookbackDays        Int       @default(7)
  lastCommentedPostId String?
  addedAt             DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  account   InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([accountId])
}

model InstagramPromptVariant {
  id        String   @id @default(cuid())
  unitId    String
  name      String
  prompt    String   @db.Text
  isActive  Boolean  @default(true)
  wins      Int      @default(0)
  losses    Int      @default(0)
  totalUses Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([unitId])
}

model InstagramStoryReplyConfig {
  id                String   @id @default(cuid())
  unitId            String
  accountId         String   @unique
  isActive          Boolean  @default(false)
  personalityPrompt String?  @db.Text
  requireApproval   Boolean  @default(false)
  replyToMentions   Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  account   InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([unitId])
}

// ─── VIP Data ────────────────────────────────────────────────────────────────

model VipDataServico {
  id          String   @id @default(cuid())
  unitId      String
  erpId       Int?     // ERP: produtos.id
  nome        String
  tipo        String?  // ERP: tipo (S=servico, P=produto)
  categoria   String?  // ERP: categoria
  preco       Float    @default(0)  // ERP: valor_venda
  valorCompra Float?   // ERP: valor_compra
  duracao     Int?     // minutos
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([unitId, erpId])
  @@index([unitId])
  @@index([erpId])
}

model VipDataFolga {
  id              String   @id @default(cuid())
  unitId          String
  erpId           Int?     // ERP: agendas_fechamentos.id
  colaboradorId   String?  // null = folga da unidade
  colaboradorErpId Int?    // ERP: agendas_fechamentos.colaborador
  colaboradorNome String?
  tipo            String   @default("fixa") // fixa | flutuante | ferias | falta
  data            DateTime
  dataFim         DateTime? // ERP: data_fim (para bloqueios com período)
  motivo          String?
  aprovada        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([unitId, erpId])
  @@index([unitId])
  @@index([colaboradorId])
  @@index([erpId])
}

model VipDataFeriado {
  id         String   @id @default(cuid())
  unitId     String
  nome       String
  data       DateTime
  tipo       String   @default("nacional") // nacional | estadual | municipal | custom
  recorrente Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([unitId])
}

model VipDataRelatorioSemanal {
  id           String   @id @default(cuid())
  unitId       String
  semanaInicio DateTime
  semanaFim    DateTime
  titulo       String?
  conteudo     Json
  criadoPor    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([unitId])
  @@index([semanaInicio])
}

model VipDataSyncLog {
  id                     String    @id @default(cuid())
  unitId                 String
  tipo                   String    @default("manual") // auto | manual | full_history
  status                 String    @default("running") // running | success | error
  registrosSincronizados Int       @default(0)
  erros                  Int       @default(0)
  detalhes               Json?
  iniciadoEm             DateTime  @default(now())
  finalizadoEm           DateTime?

  @@index([unitId])
  @@index([iniciadoEm])
}

// ─── VipCam ───────────────────────────────────────────────────────────────────

model VipCamCamera {
  id            String   @id @default(cuid())
  unitId        String
  nome          String
  localizacao   String?
  rtspUrl       String?  @db.Text
  isActive      Boolean  @default(true)
  resolucao     String?  // ex: "1920x1080"
  fpsTarget     Int      @default(15)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  eventos       VipCamCameraEvento[]
  emocoes       VipCamEmocaoRecord[]

  @@index([unitId])
}

model VipCamPessoa {
  id             String    @id @default(cuid())
  unitId         String
  nomeExibicao   String?
  tipoPessoa     String    @default("unknown") // unknown | cliente | colaborador
  primeiraVista  DateTime?
  ultimaVista    DateTime?
  totalVisitas   Int       @default(0)
  avgSatisfacao  Float?
  idadeEstimada  Int?
  generoEstimado String?   // M | F | unknown
  thumbnailPath  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  emocoes   VipCamEmocaoRecord[]

  @@index([unitId])
  @@index([tipoPessoa])
}

model VipCamEmocaoRecord {
  id               String   @id @default(cuid())
  unitId           String
  pessoaId         String
  cameraId         String
  raiva            Float    @default(0)
  desprezo         Float    @default(0)
  desgosto         Float    @default(0)
  medo             Float    @default(0)
  felicidade       Float    @default(0)
  neutro           Float    @default(0)
  tristeza         Float    @default(0)
  surpresa         Float    @default(0)
  emocaoDominante  String?
  valence          Float?
  arousal          Float?
  satisfacaoScore  Float?
  faceConfianca    Float?
  capturedAt       DateTime @default(now())

  pessoa   VipCamPessoa  @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
  camera   VipCamCamera  @relation(fields: [cameraId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([pessoaId])
  @@index([cameraId])
  @@index([capturedAt])
}

model VipCamCameraEvento {
  id              String   @id @default(cuid())
  unitId          String
  cameraId        String
  tipoEvento      String   // occupancy_snapshot | alert | person_detected
  pessoaCount     Int      @default(0)
  clienteCount    Int      @default(0)
  colaboradorCount Int     @default(0)
  avgSentimento   Float?
  avgSatisfacao   Float?
  detalhes        Json?
  capturedAt      DateTime @default(now())

  camera   VipCamCamera @relation(fields: [cameraId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([cameraId])
  @@index([capturedAt])
}

model VipCamSettings {
  id                String   @id @default(cuid())
  unitId            String   @unique
  faceThreshold     Float    @default(0.45)
  yoloConfianca     Float    @default(0.5)
  emaAlpha          Float    @default(0.3)
  fpsTarget         Int      @default(15)
  pipelineAtivo     Boolean  @default(false)
  backendUrl        String?  // URL do serviço Python VipCam
  updatedAt         DateTime @updatedAt

  @@index([unitId])
}

// ─── Churn Prediction Models ──────────────────────────────────────────────────

model ChurnPrediction {
  id                  Int      @id @default(autoincrement())
  clienteId           String
  unidadeId           String
  scoreRisco          Int      @db.TinyInt
  probabilidade       Float
  features            Json?
  previsaoData        DateTime
  proximaVisitaPrevista String?
  status              String   @default("ativo")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  cliente BarbershopCliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  unidade Unit @relation(fields: [unidadeId], references: [id])

  @@index([clienteId])
  @@index([previsaoData])
  @@index([status])
  @@index([unidadeId])
}

model ChurnAcao {
  id            Int      @id @default(autoincrement())
  clienteId     String
  unidadeId     String
  tipoAcao      String
  mensagem      String?
  status        String @default("pendente")
  dataAcao      DateTime?
  responseData  Json?
  createdAt     DateTime @default(now())

  cliente BarbershopCliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  unidade Unit @relation(fields: [unidadeId], references: [id])

  @@index([clienteId])
  @@index([status])
  @@index([dataAcao])
}

model ChurnLog {
  id                    Int      @id @default(autoincrement())
  unitId                String
  clienteId             String
  tipoProcessamento     String
  registrosAnalizados   Int
  previsoesGeradas      Int
  acoesDisparadas       Int
  status                String
  erroMensagem          String?
  durationMs            Int
  createdAt             DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id])
  cliente BarbershopCliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([clienteId])
  @@index([createdAt])
}

model ChurnAcaoConfig {
  id              Int      @id @default(autoincrement())
  unidadeId       String?
  tipoAcao        String
  ativo           Boolean @default(true)
  mensagemTemplate String?
  scoreMin        Int @default(0)
  scoreMax        Int @default(100)
  criadoEm        DateTime @default(now())

  @@index([unidadeId])
}
